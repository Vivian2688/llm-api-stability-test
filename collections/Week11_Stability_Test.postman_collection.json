                  "    pm.expect(json).to.have.property(\"error\");\r",
                  "    pm.expect(json.error).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "// 3️⃣ 严格结构校验\r",
                  "pm.test(\"Error schema strictly aligned\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    const e = json.error;\r",
                  "\r",
                  "    pm.expect(e).to.have.property(\"code\");\r",
                  "    pm.expect(e).to.have.property(\"type\");\r",
                  "    pm.expect(e).to.have.property(\"message\");\r",
                  "\r",
                  "    pm.expect(e.code).to.be.a(\"string\");\r",
                  "    pm.expect(e.type).to.be.a(\"string\");\r",
                  "    pm.expect(e.message).to.be.a(\"string\");\r",
                  "\r",
                  "    const allowed = [\"code\",\"type\",\"message\"];\r",
                  "    Object.keys(e).forEach(k => {\r",
