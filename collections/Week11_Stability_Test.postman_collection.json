    {
      "name": "A_same_case_loop",
      "item": [
        {
          "name": "01_long_prompt",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function randomSentence() {\r",
                  "    const words = [\"人工智能\", \"系统\", \"模型\", \"算法\", \"优化\", \"数据\", \"安全\", \"分析\", \"应用\"];\r",
                  "    let sentence = \"\";\r",
                  "    for (let i = 0; i < 10; i++) {\r",
                  "        sentence += words[Math.floor(Math.random() * words.length)] + \" \";\r",
                  "    }\r",
                  "    return sentence + \"。\";\r",
                  "}\r",
                  "\r",
                  "let longText = \"\";\r",
                  "for (let i = 0; i < 500; i++) {\r",
                  "    longText += randomSentence();\r",
                  "}\r",
                  "\r",
                  "pm.environment.set(\"long_prompt_text\", longText);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 2xx\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200,201,202]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Main content exists\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.choices[0].message.content).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"latency_ms\", pm.response.responseTime);\r",
                  "pm.environment.set(\"testcase_id\", pm.info.requestName);\r",
                  "\r",
                  "pm.test(\"Long prompt handled\", function () {\r",
                  "    const content = pm.response.json().choices[0].message.content;\r",
                  "    pm.expect(content.length).to.be.greaterThan(10);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
